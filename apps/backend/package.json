{
  "name": "@dydyd/backend",
  "version": "1.0.0",
  "description": "DYDYD Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint 'src/**/*.ts'",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@dydyd/shared": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.5.0",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.0",
    "firebase-admin": "^12.0.0",
    "hono": "^4.7.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.12",
    "uuid": "^9.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "prisma": "5.22.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
